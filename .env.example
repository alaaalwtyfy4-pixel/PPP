# =============================================================================
# Agency Marketing OS — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database (Async PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agency_os

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-64-char-secret

# --- Application ---
APP_NAME=Agency Marketing OS
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Meta Graph API ---
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=

# --- TikTok Marketing API ---
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# --- AWS S3 (Media Storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=agency-os-media
AWS_REGION=me-south-1

# --- Telegram Bot ---
TELEGRAM_DEFAULT_BOT_TOKEN=
